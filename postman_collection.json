						"body": {
							"mode": "raw",
							"raw": "{\n    \"productName\": \"Smart Watch\",\n    \"price\": 199.99,\n    \"rating\": 4.8,\n    \"discount\": 15,\n    \"availability\": \"In Stock\",\n    \"category\": \"Electronics\",\n    \"company\": \"TechBrand\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/products",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"products"
							]
						}
					},
					"response": []
				},
				{
